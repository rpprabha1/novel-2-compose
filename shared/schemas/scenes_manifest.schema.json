{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scenes_manifest.schema.json",
  "title": "ScenesManifest",
  "description": "Output of 01_manuscript_ingestion: the ordered list of scenes split from one manuscript, with boundary metadata preserved as plain fields (no interpretation).",
  "type": "object",
  "required": ["run_id", "manuscript_ref", "scenes"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "manuscript_ref": { "type": "string" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "order", "chapter_number", "scene_number_in_chapter", "heading_text", "file_ref"],
        "additionalProperties": false,
        "properties": {
          "scene_id": { "type": "string" },
          "order": { "type": "integer", "minimum": 0 },
          "chapter_number": { "type": "integer", "minimum": 1 },
          "scene_number_in_chapter": { "type": "integer", "minimum": 1 },
          "heading_text": { "type": "string", "description": "Raw chapter+scene marker lines, verbatim, for traceability" },
          "file_ref": { "type": "string" },
          "pov_character": { "type": "string" }
        }
      }
    }
  }
}
