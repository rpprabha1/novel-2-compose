{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "assets_manifest.schema.json",
  "title": "AssetsManifest",
  "type": "object",
  "required": ["run_id", "scene_id", "assets"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat_id", "asset_id", "origin", "file_ref", "duration_s", "license", "attribution"],
        "additionalProperties": false,
        "properties": {
          "beat_id": { "type": "string" },
          "asset_id": { "type": "string" },
          "origin": { "type": "string", "enum": ["retrieved_verified", "generated_fallback"] },
          "file_ref": { "type": "string" },
          "duration_s": { "type": "number", "exclusiveMinimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "license": { "type": "string" },
          "attribution": {
            "type": "object",
            "required": ["source", "creator_required"],
            "additionalProperties": false,
            "properties": {
              "source": { "type": "string" },
              "creator": { "type": "string" },
              "creator_required": { "type": "boolean" },
              "source_url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
