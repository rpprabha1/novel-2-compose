{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "timeline.schema.json",
  "title": "Timeline",
  "type": "object",
  "required": ["run_id", "scene_id", "clips"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "clips": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["shot_id", "file_ref", "source_in_s", "source_out_s", "timeline_start_s", "timeline_end_s"],
        "additionalProperties": false,
        "properties": {
          "shot_id": { "type": "string" },
          "file_ref": { "type": "string" },
          "source_in_s": { "type": "number", "minimum": 0 },
          "source_out_s": { "type": "number", "exclusiveMinimum": 0 },
          "timeline_start_s": { "type": "number", "minimum": 0 },
          "timeline_end_s": { "type": "number", "exclusiveMinimum": 0 },
          "transition_out": {
            "type": "object",
            "required": ["type", "duration_s"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string" },
              "duration_s": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "total_duration_s": { "type": "number", "exclusiveMinimum": 0 }
  }
}
