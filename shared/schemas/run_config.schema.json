{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run_config.schema.json",
  "title": "RunConfig",
  "type": "object",
  "required": ["run_id", "manuscript_ref", "tone", "pacing", "music_intensity_curve", "scene_marker_convention"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "manuscript_ref": { "type": "string", "description": "Path to the source manuscript text for this run" },
    "tone": { "type": "string", "description": "Free-text tone label, e.g. gothic-suspense; maps to config/audio_spec.yaml tone->music-tag table" },
    "pacing": { "type": "string", "enum": ["slow-burn", "standard", "fast-cut", "dynamic"], "description": "Must match a preset in config/editorial_vocab.yaml" },
    "music_intensity_curve": { "type": "string", "enum": ["flat", "rising", "falling", "rise-fall"] },
    "scene_marker_convention": {
      "type": "object",
      "required": ["chapter_marker", "scene_marker"],
      "additionalProperties": false,
      "properties": {
        "chapter_marker": { "type": "string" },
        "scene_marker": { "type": "string" }
      }
    },
    "pov_character": { "type": "string" }
  }
}
