{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task_envelope.schema.json",
  "title": "TaskEnvelope",
  "type": "object",
  "required": ["envelope_id", "run_id", "stage", "attempt", "input_manifest", "run_config_ref", "expected_output_schema"],
  "additionalProperties": false,
  "properties": {
    "envelope_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string" },
    "stage": { "type": "string", "pattern": "^[0-9]{2}_[a-z_]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "input_manifest": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "run_config_ref": { "type": "string" },
    "expected_output_schema": { "type": "string" },
    "deadline_hint_s": { "type": "integer", "minimum": 1 }
  }
}
