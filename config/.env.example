# Copy to config/.env and fill in real values. Never commit config/.env.
# Only sources listed in LICENSES.md may have a key here.

# Footage sources
PEXELS_API_KEY=
PIXABAY_API_KEY=
NASA_API_KEY=
# Wikimedia Commons and Archive.org APIs do not require a key for read access.
# Mixkit and Coverr have no official public API (see LICENSES.md) - no key applicable.

# Music sources
PIXABAY_MUSIC_API_KEY=
# Uses the same PIXABAY_API_KEY above if Pixabay's music endpoint shares auth -
# verify against current Pixabay API docs before assuming.

# Generation backends (06_fallback_generation image gen, 09_audio_production TTS)
IMAGE_GEN_API_KEY=
TTS_API_KEY=

# Local LLM backend for AGENT/HYBRID stages (see config/agents.yaml). No key
# needed for Ollama running locally; override the host here only if it's not
# on the default localhost:11434.
OLLAMA_HOST=
